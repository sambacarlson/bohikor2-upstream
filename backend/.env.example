# Environment
ENV=development
PORT=8080

# Database (Neon PostgreSQL)
DATABASE_URL=postgres://user:password@ep-xxx-xxx.region.aws.neon.tech/bohikor2?sslmode=require

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-project-id"}

# Campay (Sandbox for development)
CAMPAY_API_USERNAME=your_campay_username
CAMPAY_API_PASSWORD=your_campay_password
CAMPAY_WEBHOOK_SECRET=your_campay_webhook_secret
CAMPAY_BASE_URL=https://demo.campay.net/api

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@bohikor2.com

# Timezone (Cameroon)
TIMEZONE=Africa/Douala

# Server Timeouts
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
